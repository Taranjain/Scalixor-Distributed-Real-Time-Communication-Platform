{
  "name": "node-websockets",
  "version": "2.0.0",
  "description": "Scalable WebSocket server with Auth, Rooms, Chat History, Friends & Call Logs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=19.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev src/index.ts",
