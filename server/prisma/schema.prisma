datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── User ────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  sentMessages     Message[]    @relation("sender")
  roomMemberships  RoomMember[]
  sentRequests     Friendship[] @relation("requester")
  receivedRequests Friendship[] @relation("addressee")
  callerLogs       CallLog[]   @relation("caller")
  calleeLogs       CallLog[]   @relation("callee")
}

  // ─── Room (group chat OR 1:1 DM) ────────────────────
model Room {
  id        String   @id @default(uuid())
  name      String
  isGroup   Boolean  @default(true)
  createdAt DateTime @default(now())

  members      RoomMember[]
  messages     Message[]
  codeSession  CodeSession?
}

// ─── Room Membership (join table) ───────────────────
model RoomMember {
  id       String   @id @default(uuid())
  userId   String
  roomId   String
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  room Room @relation(fields: [roomId], references: [id])

  @@unique([userId, roomId])
}

// ─── Message ────────────────────────────────────────
model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  roomId    String
  createdAt DateTime @default(now())

  sender User @relation("sender", fields: [senderId], references: [id])
  room   Room @relation(fields: [roomId], references: [id])

  @@index([roomId, createdAt])
}

// ─── Friendship ─────────────────────────────────────
model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester User @relation("requester", fields: [requesterId], references: [id])
  addressee User @relation("addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Code Session ───────────────────────────────────
model CodeSession {
  id        String   @id @default(uuid())
  roomId    String   @unique
  content   String   @default("")
  language  String   @default("javascript")
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

// ─── Call Log ───────────────────────────────────────
model CallLog {
  id        String    @id @default(uuid())
  callerId  String
  calleeId  String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  duration  Int?
  status    String    // "completed", "missed", "rejected"

  caller User @relation("caller", fields: [callerId], references: [id])
  callee User @relation("callee", fields: [calleeId], references: [id])

  @@index([callerId])
  @@index([calleeId])
}
